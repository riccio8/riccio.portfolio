---
import Layout from "../layouts/Layout.astro";

const nome = "Riccardo";
---

<Layout title="Riccardo Developer Portfolio">
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 w-full z-50 p-4">
    <div class="w-full flex justify-center items-center">
      <div
        class="w-[65%] md:w-[35%] lg:w-[22%] flex justify-between items-center bg-slate-900/50 backdrop-blur-xl p-1 px-8 rounded-full relative shadow-lg"
      >
        <a
          href="#"
          id="home"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full z-10 fill-white cursor-pointer transition-color duration-500 ease-in-out"
        >
          <box-icon
            name="home"
            id="home-bg"
            class="absolute fill-[#75747A] transition duration-1000 ease-in-out hidden"
          ></box-icon>
          <box-icon name="home" animation="tada-hover" class="z-10"></box-icon>
        </a>

        <a
          href="#about"
          id="info"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full z-10 fill-[#75747A] cursor-pointer transition-color duration-500 ease-in-out"
        >
          <box-icon
            name="info-circle"
            id="info-bg"
            class="absolute fill-[#75747A] transition duration-1000 ease-in-out hidden"
          ></box-icon>
          <box-icon name="info-circle" animation="tada-hover" class="z-10"
          ></box-icon>
        </a>

        <a
          href="#competenze"
          id="skills"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full z-10 fill-[#75747A] cursor-pointer transition-color duration-500 ease-in-out"
        >
          <box-icon
            name="code-alt"
            id="contacts-bg"
            class="nav-btn absolute fill-[#75747A] transition duration-1000 ease-in-out hidden"
          ></box-icon>
          <box-icon name="code-alt" animation="tada-hover" class="z-10"
          ></box-icon>
        </a>

        <a
          href="#projects"
          id="project"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full z-10 fill-[#75747A] cursor-pointer transition-color duration-500 ease-in-out"
        >
          <box-icon
            name="folder"
            id="projects-bg"
            class="absolute fill-[#75747A] transition duration-1000 ease-in-out hidden"
          ></box-icon>
          <box-icon name="folder" animation="tada-hover" class="z-10"
          ></box-icon>
        </a>

        <a
          href="#contacts"
          id="contact"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full z-10 fill-[#75747A] cursor-pointer transition-color duration-500 ease-in-out"
        >
          <box-icon
            name="envelope"
            id="contacts-bg"
            class="absolute fill-[#75747A] transition duration-1000 ease-in-out hidden"
          ></box-icon>
          <box-icon name="envelope" animation="tada-hover" class="z-10"
          ></box-icon>
        </a>

        <div
          id="selector"
          class="nav-btn w-[60px] h-[60px] flex justify-center items-center rounded-full bg-[#131217] absolute left-0 transition duration-500 ease-[cubic-bezier(0.68,-0.55,0.27,1.55)]"
          style="transform: translateX(32px);"
        >
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section
    class="h-screen flex flex-col items-center justify-center text-center px-4"
  >
    <h1 class="text-6xl md:text-8xl font-bold tracking-tight">
      Riccardo Adami
    </h1>

    <h2 class="text-lg md:text-2xl text-slate-300 mt-3">
      Embedded & Web Developer
    </h2>

    <p
      class="text-base md:text-xl text-slate-400 max-w-xl mt-6 leading-relaxed"
    >
      Lavoro su sistemi embedded e sto iniziando a creare interfacce web
      moderne.
      <span class="block mt-2">
        Focus su performance, efficienza e software leggero.
      </span>
    </p>

    <a
      href="#about"
      class="mt-16 gap-10 md:gap-16 w-12 h-12 flex items-center justify-center rounded-full
          bg-white/5 backdrop-blur-xl border border-white/10
          hover:bg-white/10 transition"
    >
      <title>arrow</title>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-slate-200 animate-bounce"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </a>
  </section>

  <!-- Sezione Info -->
  <section id="about" class="min-h-screen pt-32 pb-16 text-white px-4 md:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Intestazione Sezione -->
      <div class="mb-16 text-center md:text-left">
        <h2
          class="text-xs font-semibold uppercase tracking-widest text-blue-400 mb-2"
        >
          Il mio percorso
        </h2>
        <h3 class="text-4xl font-bold tracking-tight">
          Esperienza ed Istruzione
        </h3>
      </div>

      <!-- Griglia Principale: Timeline a sinistra, Card a destra -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Colonna Timeline (Senza sfondi aggiuntivi) -->
        <div
          class="md:col-span-2 space-y-12 relative before:absolute before:left-3 before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-800"
        >
          <!-- Blocco 1: Scuola -->
          <div class="relative pl-10 group">
            <!-- Pallino della Timeline -->
            <div
              class="absolute left-1.5 top-2 w-3 h-3 rounded-full bg-blue-500 border-4 border-slate-950 group-hover:scale-125 transition"
            >
            </div>

            <div class="flex items-center gap-3 mb-1">
              <span
                class="text-xs px-2 py-0.5 rounded-full bg-blue-500/10 text-blue-400 font-medium border border-blue-500/20"
                >In Corso</span
              >
              <span class="text-sm text-slate-400">2026 — Presente</span>
            </div>
            <h4 class="text-xl font-semibold text-slate-100">
              Quarta Superiore Tecnico in Informatica
            </h4>
            <p class="text-sm text-slate-400 font-medium mb-3">
              ITT G. Marconi - Rovereto
            </p>
            <p class="text-slate-400 text-sm leading-relaxed">
              Sto affrontando l'indirizzo informatico focalizzato sull'analisi,
              progettazione di sistemi software complessi, gestione delle reti,
              telecomunicazioni e sistemi esperti. Questo percorso mi sta dando
              le basi metodologiche sia per il software leggero che per
              l'integrazione con i sistemi fisici.
            </p>
          </div>

          <!-- Blocco 2: Stage Estivo / Alternanza -->
          <div class="relative pl-10 group">
            <div
              class="absolute left-1.5 top-2 w-3 h-3 rounded-full bg-emerald-500 border-4 border-slate-950 group-hover:scale-125 transition"
            >
            </div>

            <div class="flex items-center gap-3 mb-1">
              <span
                class="text-xs px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 font-medium border border-emerald-500/20"
                >Completato</span
              >
              <span class="text-sm text-slate-400">Estate 2026</span>
            </div>
            <h4 class="text-xl font-semibold text-slate-100">
              Tirocinio Formativo (Sviluppo Software)
            </h4>
            <p class="text-sm text-slate-400 font-medium mb-3">
              Europe Exchange Spagna
            </p>
            <p class="text-slate-400 text-sm leading-relaxed">
              Esperienza all'estero situato in Torrox Costa, Spagna, tramite
              agenzia Europe Exchange, 14 giorni, di cui 10 lavorativi,
              incentrati sulla formazione in campi come eletronica, MCU
              (arduino, esp), sistemi esperti e basi di meccanica e automazione.
            </p>
          </div>

          <!-- Blocco 3: Progetti Extra o Scolastici -->
          <div class="relative pl-10 group">
            <div
              class="absolute left-1.5 top-2 w-3 h-3 rounded-full bg-purple-500 border-4 border-slate-950 group-hover:scale-125 transition"
            >
            </div>

            <div class="flex items-center gap-3 mb-1">
              <span
                class="text-xs px-2 py-0.5 rounded-full bg-purple-500/10 text-purple-400 font-medium border border-purple-500/20"
                >Progetto</span
              >
              <span class="text-sm text-slate-400">Anno 2024-2026</span>
            </div>
            <h4 class="text-xl font-semibold text-slate-100">
              Lan Party / Fermi MasterClass
            </h4>
            <p class="text-slate-400 text-sm leading-relaxed">
              Lan Party - creazione di un videogioco tramite la piattaforma
              Unity
            </p>
            <p class="text-sm text-slate-400 font-medium mb-3">
              Gestione rete locale per creazione lobby virtuale e istanza di
              gioco condivisa
            </p>
          </div>
        </div>

        <!-- Colonna Laterale: Card in stile Navbar (bg-slate-900/60 + blur) -->
        <div class="space-y-8">
          <!-- Card Certificazioni -->
          <div
            class="bg-slate-900/60 border border-white/10 p-6 rounded-2xl backdrop-blur-xl shadow-lg"
          >
            <h4
              class="text-lg font-semibold text-slate-200 mb-4 flex items-center gap-2"
            >
              <box-icon name="award" class="fill-blue-400 w-5 h-5"></box-icon> Certificazioni
            </h4>
            <ul class="space-y-4">
              <li class="border-l-2 border-blue-500 pl-3">
                <p class="text-sm font-medium text-slate-200">Cisco CCNA</p>
                <p class="text-xs text-slate-500">Networking Academy</p>
                <p class="text-xs text-slate-500">In corso</p>
              </li>
              <li class="border-l-2 border-blue-500 pl-3">
                <p class="text-sm font-medium text-slate-200">
                  Cambridge B2 certificate
                </p>
                <p class="text-xs text-slate-500">Completato</p>
              </li>
              <li class="border-l-2 border-blue-500 pl-3">
                <p class="text-sm font-medium text-slate-200">
                  Europe Exchange formation
                </p>
                <p class="text-xs text-slate-500">Completato</p>
              </li>
            </ul>
          </div>

          <!-- Card Filosofia Embedded & Web -->
          <div
            class="bg-slate-900/60 border border-white/10 p-6 rounded-2xl backdrop-blur-xl shadow-lg"
          >
            <h4
              class="text-lg font-semibold text-slate-200 mb-3 flex items-center gap-2"
            >
              <box-icon name="code-alt" class="fill-purple-400 w-5 h-5"
              ></box-icon> Il mio Focus
            </h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              Avendo un background orientato ai sistemi <strong>Embedded</strong
              > (C/Rust, microcontrollori, hardware), porto la stessa mentalità di
              efficienza, gestione della memoria e zero sprechi anche nel mondo del
              <strong>Web Development</strong> moderno con strumenti come Astro e
              Tailwind.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Sezione Competenze -->
  <section
    id="competenze"
    class="min-h-screen pt-32 pb-16 text-white px-6 md:px-8"
  >
    <div class="flex justify-center p-4 w-full">
      <!-- 1. CARTA ESTERNA -->
      <div
        class="w-full max-w-md overflow-hidden rounded-2xl border border-slate-800 shadow-2xl bg-[#0d1117]"
      >
        <!-- 2. IFRAME  -->
        <iframe
          src="https://github.cards/riccio8?template=Receipt"
          title="GitHub Activity Receipt"
          class="w-full h-[650px] border-none block"
          loading="lazy"
        >
        </iframe>
      </div>
    </div>
  </section>

  <!-- Sezione Progetti -->
  <section
    id="projects"
    class="min-h-screen pt-32 pb-16 text-white px-4 md:px-8"
  >
  </section>
  <!-- Card Progetto 1: IdroStoria (Sito dell'acqua) -->

  <!-- Card Progetto 2: Servizio Freelance -->

  <!-- Sezione Contatti -->
  <section
    id="contacts"
    class="min-h-screen pt-32 pb-16 text-white px-4 md:px-8"
  >
    <div class="max-w-3xl mx-auto text-center">
      <!-- Titolo -->
      <h2
        class="text-xs font-semibold uppercase tracking-widest text-blue-400 mb-2"
      >
        Contatti
      </h2>
      <h3 class="text-4xl font-bold tracking-tight mb-6">Contattami</h3>
      <p class="text-slate-400 mb-10 max-w-md mx-auto text-sm md:text-base">
        Hai un progetto, un'idea o vuoi semplicemente scrivermi? Compila il form
        oppure usa i contatti diretti qui sotto.
      </p>

      <!-- FORM (iOS Glassmorphism) -->
      <form
        id="contactForm"
        class="relative bg-white/[0.06] border border-white/20 p-6 md:p-8 rounded-3xl backdrop-blur-2xl shadow-2xl space-y-5 overflow-hidden text-left"
      >
        <!-- iOS Light Reflection Overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-white/[0.08] to-transparent pointer-events-none"
        >
        </div>

        <div>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Il tuo nome"
            required
            class="w-full p-3.5 rounded-2xl bg-white/[0.05] border border-white/[0.08] text-white placeholder-slate-400/70 focus:outline-none focus:bg-white/[0.1] focus:border-blue-400/50 backdrop-blur-xl transition-all duration-200"
          />
        </div>

        <div>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="La tua email"
            required
            class="w-full p-3.5 rounded-2xl bg-white/[0.05] border border-white/[0.08] text-white placeholder-slate-400/70 focus:outline-none focus:bg-white/[0.1] focus:border-blue-400/50 backdrop-blur-xl transition-all duration-200"
          />
        </div>

        <div>
          <textarea
            id="message"
            name="message"
            placeholder="Scrivi il tuo messaggio..."
            rows="5"
            required
            class="w-full p-3.5 rounded-2xl bg-white/[0.05] border border-white/[0.08] text-white placeholder-slate-400/70 focus:outline-none focus:bg-white/[0.1] focus:border-blue-400/50 backdrop-blur-xl transition-all duration-200 resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-3.5 rounded-2xl bg-blue-500/80 hover:bg-blue-500 backdrop-blur-md border border-white/20 shadow-lg shadow-blue-500/10 transition-all duration-300 hover:scale-[1.01] active:scale-[0.99] font-medium text-white tracking-wide"
        >
          Invia Messaggio
        </button>
      </form>

      <!-- CONTATTI DIRETTI -->
      <div class="mt-12 space-y-3 text-sm md:text-base text-slate-300">
        <p>
          Email:
          <a
            href="mailto:riccioadami@gmail.com?subject=Contatto%20dal%20Portfolio"
            class="text-blue-400 hover:text-blue-300 transition underline decoration-blue-400/30 underline-offset-4"
          >
            riccioadami@gmail.com
          </a>
        </p>
        <p>
          Telefono:
          <a
            href="tel:+393806384755"
            class="text-blue-400 hover:text-blue-300 transition underline decoration-blue-400/30 underline-offset-4"
          >
            +39 3806384755
          </a>
        </p>
      </div>

      <!-- SOCIAL LINK (iOS Style Capsule) -->
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a
          href="https://github.com/riccio8"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 rounded-full bg-white/[0.04] border border-white/10 text-sm font-medium hover:bg-white/[0.1] hover:border-white/20 transition-all active:scale-95 flex items-center gap-2"
        >
          <span>GitHub</span>
        </a>
        <a
          href="https://www.instagram.com/riccio_adaa/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 rounded-full bg-white/[0.04] border border-white/10 text-sm font-medium hover:bg-white/[0.1] hover:border-white/20 transition-all active:scale-95 flex items-center gap-2"
        >
          <span>Instagram</span>
        </a>
        <a
          href="https://open.spotify.com/user/31nmlqb3jdu55q6dskpt7fzcy7j4"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 rounded-full bg-white/[0.04] border border-white/10 text-sm font-medium hover:bg-white/[0.1] hover:border-white/20 transition-all active:scale-95 flex items-center gap-2"
        >
          <span>Spotify</span>
        </a>
      </div>
    </div>
  </section>

  <footer
    class="py-8 text-center text-xs text-slate-500 border-t border-white/[0.05]"
  >
    &copy; 2026 — <a
      href="mailto:riccioadami@gmail.com"
      class="hover:text-slate-400 transition">riccioadami@gmail.com</a
    >
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById(
        "contactForm",
      ) as HTMLFormElement | null;
      if (!form) return;

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const nameInput = document.getElementById(
          "name",
        ) as HTMLInputElement | null;
        const emailInput = document.getElementById(
          "email",
        ) as HTMLInputElement | null;
        const messageInput = document.getElementById(
          "message",
        ) as HTMLTextAreaElement | null;

        if (nameInput && emailInput && messageInput) {
          const subject = encodeURIComponent("Nuovo contatto dal portfolio");
          const body = encodeURIComponent(
            `Nome: ${nameInput.value}\nEmail: ${emailInput.value}\n\nMessaggio:\n${messageInput.value}`,
          );

          window.location.href = `mailto:riccioadami@gmail.com?subject=${subject}&body=${body}`;
        }
      });
    });
  </script>
  <!-- Footer -->
</Layout>
