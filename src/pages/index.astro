---
import Layout from '../layouts/Layout.astro';

// Qui puoi definire variabili JavaScript se ti servono
const nome = "Riccardo";
---

<Layout title="Riccardo | Frontend Developer Portfolio">
	<!-- Navbar -->
	<header class="fixed top-0 left-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-900">
		<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
			<span class="font-mono font-bold text-emerald-400 text-lg">&lt;{nome}.dev /&gt;</span>
			<nav class="flex gap-6 text-sm font-medium text-slate-400">
				<a href="#home" class="hover:text-white transition">Home</a>
				<a href="#progetti" class="hover:text-white transition">Progetti</a>
				<a href="#contatti" class="hover:text-white transition">Contatti</a>
			</nav>
		</div>
	</header>

	<!-- Hero Section -->
	<main id="home" class="pt-32 pb-16 px-6 max-w-4xl mx-auto text-center space-y-6">
		<h1 class="text-5xl md:text-6xl font-black tracking-tight text-white">
			Sviluppo interfacce <br />
			<span class="bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent">rapide e moderne</span>
		</h1>
		<p class="text-lg text-slate-400 max-w-xl mx-auto">
			Sono uno sviluppatore Frontend specializzato in performance, architetture Jamstack ed esperienze web responsive curate nei minimi dettagli.
		</p>
		<div class="flex justify-center gap-4 pt-4">
			<a href="#progetti" class="bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-bold px-6 py-3 rounded-xl transition shadow-lg shadow-emerald-500/10">
				Vedi i miei lavori
			</a>
			<a href="#contatti" class="border border-slate-800 hover:bg-slate-900 text-white font-medium px-6 py-3 rounded-xl transition">
				Contattami
			</a>
		</div>
	</main>

	<!-- Sezione Progetti -->
	<section id="progetti" class="max-w-5xl mx-auto px-6 py-20 border-t border-slate-900">
		<h2 class="text-3xl font-bold text-white mb-2">Progetti Evidenziati</h2>
		<p class="text-slate-400 mb-10 text-sm">Una selezione dei lavori che ho sviluppato recentemente.</p>
		
		<div class="grid md:grid-cols-2 gap-6">
			<!-- Card Progetto 1: IdroStoria (Sito dell'acqua) -->
			<div class="p-6 bg-slate-900/50 border border-slate-800 rounded-2xl flex flex-col justify-between hover:border-slate-700 transition">
				<div class="space-y-3">
					<span class="text-xs font-mono text-emerald-400 bg-emerald-500/10 px-2 py-1 rounded">HTML • CSS • Bootstrap</span>
					<h3 class="text-xl font-bold text-white">IdroStoria</h3>
					<p class="text-sm text-slate-400 leading-relaxed">
						Landing page interattiva focalizzata sull'ottimizzazione del layout responsive e sull'implementazione di animazioni avanzate legate allo scorrimento della pagina.
					</p>
				</div>
				<div class="pt-6">
					<a href="INCOLLA_IL_LINK_DI_VERCEL_DEL_SITO_DELL_ACQUA" target="_blank" class="inline-flex items-center text-xs font-mono text-white bg-slate-800 px-4 py-2 rounded-lg hover:bg-slate-700 transition">
						Sito Live <span class="ml-1">→</span>
					</a>
				</div>
			</div>

			<!-- Card Progetto 2: Servizio Freelance -->
			<div class="p-6 bg-slate-900/50 border border-slate-800 rounded-2xl flex flex-col justify-between hover:border-slate-700 transition">
				<div class="space-y-3">
					<span class="text-xs font-mono text-teal-400 bg-teal-500/10 px-2 py-1 rounded">Vercel • DevOps • Git</span>
					<h3 class="text-xl font-bold text-white">Deploy & Cloud Optimization</h3>
					<p class="text-sm text-slate-400 leading-relaxed">
						Configurazione di pipeline CI/CD automatiche collegate a GitHub, ottimizzazione delle performance di caricamento e gestione record DNS per domini personalizzati.
					</p>
				</div>
				<div class="pt-6">
					<a href="INCOLLA_IL_PROFILO_FIVERR" target="_blank" class="inline-flex items-center text-xs font-mono text-white bg-slate-800 px-4 py-2 rounded-lg hover:bg-slate-700 transition">
						Contratta su Fiverr <span class="ml-1">→</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Sezione Contatti -->
	<section id="contatti" class="max-w-4xl mx-auto px-6 py-20 text-center border-t border-slate-900 space-y-4">
		<h2 class="text-2xl font-bold text-white">Let's build something together</h2>
		<p class="text-slate-400 max-w-md mx-auto text-sm">
			Hai un progetto da sviluppare o hai bisogno di configurare il deploy del tuo sito aziendale? Scrivimi.
		</p>
		<p class="text-emerald-400 font-mono pt-2 text-lg">la-tua-email@esempio.com</p>
	</section>

	<!-- Footer -->
	<footer class="border-t border-slate-900 py-8 text-center text-xs text-slate-600 font-mono">
		&copy; {new Date().getFullYear()} {nome}. Sviluppato con Astro e Tailwind.
	</footer>
</Layout>